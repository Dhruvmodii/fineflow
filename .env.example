# Copy this to .env.local for local dev, and add these in Netlify → Site settings → Environment variables

# Neon PostgreSQL connection string
# Get from: console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://username:password@ep-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# JWT Secret — use a long random string (e.g. run: openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-change-this

# SMTP for email reports
# Gmail: enable 2FA, then create an "App Password" at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
